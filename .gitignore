# =========================
# 1. Python 编译与缓存文件
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.coverage
htmlcov/

# =========================
# 2. 虚拟环境 (非常重要！)
# =========================
# 绝对不要把虚拟环境提交到 Git，别人下载后自己重新装依赖即可
venv/
.venv/
env/
.env/
pip-log.txt
pip-delete-this-directory.txt

# =========================
# 3. 打包与分发文件夹
# =========================
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =========================
# 4. VS Code 编辑器配置
# =========================
# 忽略个人的 VS Code 工作区设置和历史记录
.vscode/*
# 如果你希望团队共享 debug 配置或特定的项目设置，可以取消下面两行的注释
# !.vscode/settings.json
# !.vscode/launch.json

# =========================
# 5. 操作系统自动生成的文件
# =========================
.DS_Store
Thumbs.db

# =========================
# 6. 本地环境变量/机密配置
# =========================
# 包含数据库密码、API Key 的本地文件必须忽略
.env
.env.local